# Jira REST API — required to download test plan Excel attachments from Jira issues.
# Atlassian MCP (Cursor) reads issue metadata; Python scripts use this token for attachment binaries.
# Copy to .env and fill in your values (never commit .env).
#
# Create token: https://id.atlassian.com/manage-profile/security/api-tokens

# Required when a test plan is attached on the Jira issue (e.g. Domino Test Plan.xlsx)
ATLASSIAN_EMAIL=you@wbd.com
ATLASSIAN_API_TOKEN=your-api-token-here

# Optional aliases (scripts accept either naming)
# JIRA_EMAIL=
# JIRA_API_TOKEN=
