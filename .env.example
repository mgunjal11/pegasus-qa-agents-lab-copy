# Jira REST API — required to download test plan Excel attachments from Jira issues.
# Atlassian MCP (Cursor) reads issue metadata; Python scripts use this token for attachment binaries.
# Copy to .env and fill in your values (never commit .env).
# Preflight and install_coverage_validator_permissions.py create .env from this file when missing.
#
# Create token (set expiry to 365 days / 1 year — maximum allowed):
#   https://id.atlassian.com/manage-profile/security/api-tokens

# Required when a test plan is attached on the Jira issue (e.g. Domino Test Plan.xlsx)
ATLASSIAN_EMAIL=you@wbd.com
ATLASSIAN_API_TOKEN=your-api-token-here

# Optional — record when you created the token and when it expires (365 days / 1 year max in Atlassian UI)
# Used by verify_jira_credentials.py to warn before attachment downloads fail with HTTP 401
ATLASSIAN_API_TOKEN_CREATED=2026-06-17
ATLASSIAN_API_TOKEN_EXPIRES=2027-06-17

# Optional aliases (scripts accept either naming)
# JIRA_EMAIL=
# JIRA_API_TOKEN=
